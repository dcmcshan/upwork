# Upwork API OAuth2 Credentials
# Get these from: https://www.upwork.com/services/api/apply
UPWORK_CLIENT_ID=your_client_id_here
UPWORK_CLIENT_SECRET=your_client_secret_here
UPWORK_ACCESS_TOKEN=your_access_token_here
UPWORK_REFRESH_TOKEN=your_refresh_token_here

# ============================================
# JOB APPLICATION AGENT SETTINGS
# ============================================
# Used by upwork_agent.py for automatic job applications

# Keywords to search for in job postings
JOB_KEYWORDS=python,web development,automation,API,backend

# Budget filters for automatic applications
MIN_BUDGET=50
MAX_BUDGET=500

# ============================================
# JOB MONITOR SETTINGS
# ============================================
# Used by upwork_job_monitor.py for tracking jobs

# Search queries (separate multiple terms with commas)
SEARCH_QUERIES=python,javascript,web development,AI,machine learning,data science,DevOps

# Hourly rate filters (in USD)
MIN_HOURLY_RATE=25
MAX_HOURLY_RATE=200

# Fixed price filters (in USD)
MIN_FIXED_PRICE=100
MAX_FIXED_PRICE=10000
